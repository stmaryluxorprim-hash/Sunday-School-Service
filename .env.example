# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — SERVER ONLY (used to broadcast device push to all
# users). Never expose this to the browser. Found in Supabase → Project
# Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (VAPID) keys — generate once with:  npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is safe to expose (used in the browser).
# VAPID_PRIVATE_KEY must stay server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
